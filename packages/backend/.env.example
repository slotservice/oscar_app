# ─── Database ─────────────────────────────────────────
# PostgreSQL connection string
# For local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/oscar_dev
# For AWS RDS: postgresql://postgres:YOUR_PASSWORD@your-rds-endpoint.amazonaws.com:5432/oscar_prod
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/oscar_dev"

# ─── Authentication ──────────────────────────────────
# JWT secret key — MUST change this in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-secure-random-string"

# ─── Server ──────────────────────────────────────────
PORT=3000
