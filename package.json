{
  "name": "oscar-mvp",
  "version": "1.0.0",
  "private": true,
  "description": "Oscar - Wastewater Plant Operations App",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/admin"
  ],
  "scripts": {
    "backend": "npm run dev --workspace=packages/backend",
    "admin": "npm run dev --workspace=packages/admin",
    "db:migrate": "npm run db:migrate --workspace=packages/backend",
    "db:seed": "npm run db:seed --workspace=packages/backend",
    "build": "npm run build --workspaces"
  }
}
